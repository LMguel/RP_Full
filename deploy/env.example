# deploy/env.example
# Copie para deploy/.env e preencha ANTES de rodar os scripts de deploy.
# NUNCA commitar o arquivo .env com valores reais.

# ─── AWS ──────────────────────────────────────────────────────────────────────
# Usar IAM Role no EC2 (preferido) ou credenciais de deploy dedicadas (mínimo: S3+CloudFront)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ─── EC2 Backend ──────────────────────────────────────────────────────────────
EC2_HOST=                        # ex: ec2-XX-XX-XX-XX.compute-1.amazonaws.com
EC2_USER=ubuntu                  # ou ec2-user, dependendo da AMI
EC2_SSH_KEY=~/.ssh/registraponto.pem
EC2_APP_DIR=/home/ubuntu/RP_Full/backend
EC2_VENV_DIR=/home/ubuntu/RP_Full/backend/venv

# ─── S3 Buckets ───────────────────────────────────────────────────────────────
S3_BUCKET_FRONT=                 # ex: registraponto-frontend
S3_BUCKET_PWA=                   # ex: registraponto-pwa
S3_BUCKET_FOTOS=registraponto-prod-fotos

# ─── CloudFront ───────────────────────────────────────────────────────────────
CLOUDFRONT_ID_FRONT=             # Distribution ID do frontend
CLOUDFRONT_ID_PWA=               # Distribution ID do PWA

# ─── Configurações da aplicação (produção) ────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
JWT_SECRET_KEY=

FLASK_ENV=production
FLASK_DEBUG=False
ALLOWED_ORIGINS=https://registra-ponto.duckdns.org,https://pwa.registra-ponto.duckdns.org
ENABLE_HSTS=1
MAX_UPLOAD_MB=10

# ─── DynamoDB ─────────────────────────────────────────────────────────────────
DYNAMODB_TABLE_EMPLOYEES=Employees
DYNAMODB_TABLE_RECORDS=TimeRecords
DYNAMODB_TABLE_USERS=UserCompany
DYNAMODB_TABLE_CONFIG=ConfigCompany

# ─── Rekognition ──────────────────────────────────────────────────────────────
REKOGNITION_COLLECTION=registraponto-faces
REKOGNITION_THRESHOLD=85
ENABLE_REKOGNITION=1

# ─── GROQ (chatbot RH) ────────────────────────────────────────────────────────
GROQ_API_KEY=
