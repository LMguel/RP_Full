# Configurações da API REGISTRA.PONTO
API_BASE_URL=https://api.registraponto.com.br
API_TIMEOUT_MS=15000

# Configurações de sync
SYNC_INTERVAL_MS=60000
SYNC_BATCH_SIZE=20

# Reconhecimento facial
FACE_SIMILARITY_THRESHOLD=0.82
FACE_MIN_CONFIDENCE=0.85
FACE_USE_CLOUD_FALLBACK=true

# Kiosk
KIOSK_AUTO_LOCK=true
KIOSK_BOOT_AUTO_START=true

# Debug
DEBUG_LOGS=false
