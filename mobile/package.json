{
  "name": "registra-ponto-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Terminal de ponto eletrônico Android Kiosk - REGISTRA.PONTO",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "android:win-ascii-cache": "cmd /c \"mkdir C:\\gradle-rp 2>nul & set GRADLE_USER_HOME=C:\\gradle-rp & react-native run-android\"",
    "android:release": "cd android && ./gradlew assembleRelease",
    "android:bundle": "cd android && ./gradlew bundleRelease",
    "start": "react-native start",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "cd android && ./gradlew clean && cd .. && rm -rf node_modules",
    "postinstall": "patch-package || true"
  },
  "dependencies": {
    "@bam.tech/react-native-image-resizer": "3.0.10",
    "@react-native-async-storage/async-storage": "1.24.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-ml-kit/face-detection": "1.3.2",
    "@react-navigation/native": "6.1.18",
    "@react-navigation/native-stack": "6.10.0",
    "@tanstack/react-query": "5.51.1",
    "axios": "1.7.7",
    "react": "18.3.1",
    "react-native": "0.75.4",
    "react-native-background-fetch": "4.2.5",
    "react-native-blob-util": "0.19.11",
    "react-native-bootsplash": "5.4.0",
    "react-native-device-info": "11.1.0",
    "react-native-fast-tflite": "1.6.1",
    "react-native-gesture-handler": "2.20.2",
    "react-native-get-random-values": "1.11.0",
    "react-native-keychain": "8.2.0",
    "react-native-mmkv": "2.12.2",
    "react-native-permissions": "4.1.5",
    "react-native-reanimated": "3.15.5",
    "react-native-safe-area-context": "4.11.0",
    "react-native-screens": "3.34.0",
    "react-native-sqlite-storage": "6.0.1",
    "react-native-svg": "15.7.1",
    "react-native-vision-camera": "4.7.3",
    "react-native-vision-camera-face-detector": "1.10.2",
    "react-native-worklets-core": "1.6.3",
    "uuid": "10.0.0",
    "vision-camera-resize-plugin": "3.2.0",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@babel/core": "7.25.2",
    "@babel/preset-env": "7.25.4",
    "@babel/runtime": "7.25.6",
    "@react-native/babel-preset": "0.75.4",
    "@react-native/eslint-config": "0.75.4",
    "@react-native/metro-config": "0.75.4",
    "@react-native/typescript-config": "0.75.4",
    "@types/react": "18.2.79",
    "@types/react-native-sqlite-storage": "6.0.5",
    "@types/uuid": "10.0.0",
    "babel-plugin-module-resolver": "5.0.2",
    "eslint": "8.57.0",
    "patch-package": "8.0.0",
    "prettier": "3.3.3",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18"
  }
}
